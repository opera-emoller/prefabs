    var _n = array_length(grid[_row]);
    for (var c = 0; c < _n; c++) {
        var _d = abs((grid[_row][c].x + grid[_row][c].w * 0.5) - _cx);
        if (_d < _bd) { _bd = _d; _best = c; }
    }
    return _best;
};
